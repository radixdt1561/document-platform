# App
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com

# PostgreSQL
DB_HOST=<rds_endpoint>
DB_READ_HOST=<rds_read_replica_endpoint>
DB_PORT=5432
DB_USER=postgres
DB_PASS=<strong_password>
DB_NAME=document_platform

# Auth
JWT_SECRET=<jwt_secret_min_32_chars>
REFRESH_TOKEN_SECRET=<refresh_token_secret_min_32_chars>
ENCRYPTION_KEY=<64_char_hex_string>

# Redis
REDIS_URL=redis://<elasticache_endpoint>:6379

# SMTP
SMTP_HOST=<smtp_host>
SMTP_PORT=587
SMTP_USER=<smtp_user>
SMTP_PASS=<smtp_password>

# Google OAuth
GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>
GOOGLE_CALLBACK_URL=https://yourdomain.com/auth/google/callback
OAUTH_SUCCESS_REDIRECT=https://yourdomain.com/dashboard

# AWS
AWS_ACCESS_KEY=<aws_access_key_id>
AWS_SECRET_KEY=<aws_secret_access_key>
AWS_REGION=ap-south-1
AWS_BUCKET=<s3_bucket_name>
SQS_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/<account_id>/<queue_name>
SQS_QUEUE_ARN=arn:aws:sqs:ap-south-1:<account_id>:<queue_name>

# SAM Deploy (CI/CD)
SAM_DEPLOY_BUCKET=<s3_bucket_for_sam_artifacts>

# TLS (local dev only — Lambda uses API Gateway TLS)
TLS_CERT=../certs/cert.pem
TLS_KEY=../certs/key.pem

# Memory monitoring
MEMORY_THRESHOLD_MB=400
MEMORY_CRITICAL_MB=600
MEMORY_INTERVAL_MS=30000

# Logging
LOG_LEVEL=info
CLOUDWATCH_GROUP=/document-platform
CLOUDWATCH_REGION=ap-south-1
