    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "express-rate-limit": "^7.5.0",
    "hpp": "^0.2.3",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.3",
    "redis": "^4.7.0",
    "pg": "^8.19.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-cloudwatch": "^6.3.0"
